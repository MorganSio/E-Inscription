{% extends 'base.html.twig' %}
{% block title %}Inscription - Étape {{ flow.currentStepNumber }} - E-Inscription{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .fr-fieldset {
            margin-bottom: 2rem;
        }
        .fr-alert--success {
            margin-bottom: 1rem;
        }
        .validation-error {
            color: var(--error-500);
            font-size: 0.875rem;
            margin-top: 0.25rem;
        }
        .fr-btn--disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }
        .form-error {
            color: var(--error-500);
            font-size: 0.875rem;
            margin-top: 0.25rem;
        }
        .fr-alert--error {
            margin-bottom: 1rem;
        }
        .loading-spinner {
            display: none;
            margin-left: 0.5rem;
        }
        .fr-btn--loading .loading-spinner {
            display: inline-block;
        }
        .fr-grid-row.fr-grid-row--gutters > * {
            margin-bottom: 1rem;
        }
        .field-error {
            border: 2px solid var(--error-500) !important;
            background-color: #fef2f2 !important;
        }
        .field-error-message {
            color: var(--error-500);
            font-size: 0.875rem;
            margin-top: 0.25rem;
            font-weight: 500;
        }
        .main-content {
            background-color: #fff;
            padding: 2rem;
            border-radius: 0.5rem;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }
    </style>
{% endblock %}

{% block body %}
<div class="fr-container">
    <div class="fr-grid-row fr-grid-row--center">
        <div class="fr-col-12 fr-col-lg-10">
            <nav class="fr-breadcrumb" aria-label="vous êtes ici :" role="navigation">
                <button class="fr-breadcrumb__button" aria-expanded="false" aria-controls="breadcrumb-{{ flow.currentStepNumber }}">
                    Voir le fil d'Ariane
                </button>
                <div class="fr-collapse" id="breadcrumb-{{ flow.currentStepNumber }}">
                    <ol class="fr-breadcrumb__list">
                        <li>
                            <a class="fr-breadcrumb__link" href="{{ path('app_home') }}">Accueil</a>
                        </li>
                        <li>
                            <a class="fr-breadcrumb__link" aria-current="page">Inscription</a>
                        </li>
                    </ol>
                </div>
            </nav>

            <div class="fr-stepper">
                <h2 class="fr-stepper__title" id="step-title">
                    Étape {{ flow.currentStepNumber }} sur 10 : {{ flow.currentStepLabel }}
                </h2>
                <div class="fr-stepper__steps" data-fr-current-step="{{ flow.currentStepNumber }}" data-fr-steps="10"></div>
                {% if flow.nextStepLabel is defined %}
                    <p class="fr-stepper__details">
                        <span class="fr-text--bold">Étape suivante :</span> 
                        {{ flow.nextStepLabel }}
                    </p>
                {% endif %}
            </div>

            <!-- Conteneur pour les messages d'erreur AJAX -->
            <div id="ajax-messages"></div>

            {% for flash_error in app.flashes('error') %}
                <div class="fr-alert fr-alert--error">
                    <p class="fr-alert__title">Erreur</p>
                    <p>{{ flash_error }}</p>
                </div>
            {% endfor %}

            {% for flash_success in app.flashes('success') %}
                <div class="fr-alert fr-alert--success">
                    <p class="fr-alert__title">Succès</p>
                    <p>{{ flash_success }}</p>
                </div>
            {% endfor %}

            <div class="main-content">
                {{ form_start(form, {'attr': {'id': 'inscription-form', 'novalidate': 'novalidate'}}) }}

                {% if flow.currentStepNumber == 1 %}
                    <fieldset class="fr-fieldset">
                        <legend class="fr-fieldset__legend fr-text--regular">
                            <span class="fr-icon-user-line fr-icon--sm" aria-hidden="true"></span>
                            Informations personnelles
                        </legend>
                        <div class="fr-fieldset__content">
                            <div class="fr-grid-row fr-grid-row--gutters">
                                <div class="fr-col-12 fr-col-md-6">
                                    {{ form_row(form.nom) }}
                                </div>
                                <div class="fr-col-12 fr-col-md-6">
                                    {{ form_row(form.prenom) }}
                                </div>
                            </div>
                            <div class="fr-grid-row fr-grid-row--gutters">
                                <div class="fr-col-12 fr-col-md-6">
                                    {{ form_row(form.email) }}
                                </div>
                                <div class="fr-col-12 fr-col-md-6">
                                    {{ form_row(form.dateNaissance) }}
                                </div>
                            </div>
                            <div class="fr-grid-row fr-grid-row--gutters">
