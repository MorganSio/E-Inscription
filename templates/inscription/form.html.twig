                        <legend class="fr-fieldset__legend fr-text--regular">
                            <span class="fr-icon-documents-line fr-icon--sm" aria-hidden="true"></span>
                            Documents à fournir
                        </legend>
                        <div class="fr-fieldset__content">
                            <!-- Nouveau système d'upload avec sélection de type de document -->
                            <div class="fr-grid-row fr-grid-row--gutters">
                                <div class="fr-col-12">
                                    <div class="fr-upload-group">
                                        <label class="fr-label" for="file-upload">
                                            Type de document
                                        </label>
                                        <select class="fr-select" id="document-type">
                                            <option value="carte_vitale">Carte Vitale</option>
                                            <option value="attestation_identite">Attestation d'identité</option>
                                            <option value="photo_identite">Photo d'identité</option>
                                            <option value="bourse">Justificatif de bourse</option>
                                            <option value="attestation_jdc">Attestation JDC</option>
                                            <option value="attestation_reusite">Attestation de réussite</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="fr-grid-row fr-grid-row--gutters">
                                <div class="fr-col-12">
                                    <div class="fr-upload-group">
                                        <label class="fr-label" for="file-upload">
                                            Sélectionnez un fichier (PDF, JPG, PNG - max 5MB)
                                            <span class="fr-hint-text">Formats acceptés : PDF, JPG, PNG. Taille maximum : 5MB.</span>
                                        </label>
                                        <input class="fr-upload" type="file" id="file-upload" accept=".pdf,.jpg,.jpeg,.png">
                                        <input type="hidden" name="document_file" id="document-file">
                                    </div>
                                </div>
                            </div>
                            
                            <div class="fr-grid-row fr-grid-row--gutters">
                                <div class="fr-col-12">
                                    <button type="button" class="fr-btn" id="upload-btn">
                                        <span class="fr-icon-upload-line fr-icon--sm" aria-hidden="true"></span>
                                        Uploader le document
                                    </button>
                                </div>
                            </div>

                            <hr class="fr-mt-4w fr-mb-4w">

                            <!-- Liste des documents existants -->
                            <h4 class="fr-h4">Documents enregistrés</h4>
                            <div id="documents-list" class="fr-grid-row fr-grid-row--gutters">
                                {% if infoEleve.carteVitale %}
                                    <div class="fr-col-12 fr-col-md-6">
                                        <div class="fr-card fr-card--shadowed fr-enlarge-link">
                                            <div class="fr-card__body">
                                                <h4 class="fr-card__title">
                                                    <a href="{{ path('download_pdf', {'eleveId': infoEleve.id, 'documentType': 'carteVitale'}) }}" class="fr-card__link" download>Carte Vitale</a>
                                                </h4>
                                                <p class="fr-card__desc">Fichier PDF</p>
                                            </div>
                                            <div class="fr-card__footer">
                                                <button class="fr-btn fr-btn--secondary fr-btn--sm replace-btn" data-doc-type="carteVitale">
                                                    Remplacer
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                {% endif %}
                                
                                {% if infoEleve.photoIdentite %}
                                    <div class="fr-col-12 fr-col-md-6">
                                        <div class="fr-card fr-card--shadowed fr-enlarge-link">
                                            <div class="fr-card__body">
                                                <h4 class="fr-card__title">
                                                    <a href="{{ path('download_pdf', {'eleveId': infoEleve.id, 'documentType': 'photoIdentite'}) }}" class="fr-card__link" download>Photo d'identité</a>
                                                </h4>
                                                <p class="fr-card__desc">Fichier image</p>
                                            </div>
                                            <div class="fr-card__footer">
                                                <button class="fr-btn fr-btn--secondary fr-btn--sm replace-btn" data-doc-type="photoIdentite">
                                                    Remplacer
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                {% endif %}
                                
                                {% if infoEleve.attestationIdentite %}
                                    <div class="fr-col-12 fr-col-md-6">
                                        <div class="fr-card fr-card--shadowed fr-enlarge-link">
                                            <div class="fr-card__body">
                                                <h4 class="fr-card__title">
                                                    <a href="{{ path('download_pdf', {'eleveId': infoEleve.id, 'documentType': 'attestationIdentite'}) }}" class="fr-card__link" download>Attestation d'identité</a>
                                                </h4>
                                                <p class="fr-card__desc">Fichier PDF</p>
                                            </div>
                                            <div class="fr-card__footer">
                                                <button class="fr-btn fr-btn--secondary fr-btn--sm replace-btn" data-doc-type="attestationIdentite">
                                                    Remplacer
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                {% endif %}
                                
                                {% if infoEleve.bourse %}
                                    <div class="fr-col-12 fr-col-md-6">
                                        <div class="fr-card fr-card--shadowed fr-enlarge-link">
                                            <div class="fr-card__body">
                                                <h4 class="fr-card__title">
                                                    <a href="{{ path('download_pdf', {'eleveId': infoEleve.id, 'documentType': 'bourse'}) }}" class="fr-card__link" download>Justificatif de bourse</a>
                                                </h4>
                                                <p class="fr-card__desc">Fichier PDF</p>
                                            </div>
                                            <div class="fr-card__footer">
                                                <button class="fr-btn fr-btn--secondary fr-btn--sm replace-btn" data-doc-type="bourse">
                                                    Remplacer
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                {% endif %}
                                
                                {% if infoEleve.attestationJDC %}
                                    <div class="fr-col-12 fr-col-md-6">
                                        <div class="fr-card fr-card--shadowed fr-enlarge-link">
                                            <div class="fr-card__body">
                                                <h4 class="fr-card__title">
                                                    <a href="{{ path('download_pdf', {'eleveId': infoEleve.id, 'documentType': 'attestationJDC'}) }}" class="fr-card__link" download>Attestation JDC</a>
                                                </h4>
                                                <p class="fr-card__desc">Fichier PDF</p>
                                            </div>
                                            <div class="fr-card__footer">
                                                <button class="fr-btn fr-btn--secondary fr-btn--sm replace-btn" data-doc-type="attestationJDC">
                                                    Remplacer
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                {% endif %}
                                
                                {% if infoEleve.attestationReusite %}
                                    <div class="fr-col-12 fr-col-md-6">
                                        <div class="fr-card fr-card--shadowed fr-enlarge-link">
                                            <div class="fr-card__body">
                                                <h4 class="fr-card__title">
                                                    <a href="{{ path('download_pdf', {'eleveId': infoEleve.id, 'documentType': 'attestationReusite'}) }}" class="fr-card__link" download>Attestation de réussite</a>
                                                </h4>
                                                <p class="fr-card__desc">Fichier PDF</p>
                                            </div>
                                            <div class="fr-card__footer">
                                                <button class="fr-btn fr-btn--secondary fr-btn--sm replace-btn" data-doc-type="attestationReusite">
                                                    Remplacer
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </fieldset>

                    <script>
                        document.addEventListener('DOMContentLoaded', function() {
                            const uploadBtn = document.getElementById('upload-btn');
                            const fileInput = document.getElementById('file-upload');
                            const docTypeSelect = document.getElementById('document-type');
                            
                            uploadBtn.addEventListener('click', async function() {
                                const file = fileInput.files[0];
                                const docType = docTypeSelect.value;
                                
                                if (!file) {
                                    showAlert('Veuillez sélectionner un fichier', 'error');
                                    return;
                                }
                                
                                // Vérification de la taille
                                if (file.size > 5 * 1024 * 1024) {
                                    showAlert('Le fichier est trop volumineux (max 5MB)', 'error');
                                    return;
                                }
                                
                                // Vérification du type de fichier
                                const validTypes = ['application/pdf', 'image/jpeg', 'image/png'];
                                if (!validTypes.includes(file.type)) {
                                    showAlert('Format de fichier non valide (PDF, JPG, PNG uniquement)', 'error');
                                    return;
                                }
                                
                                // Afficher l'indicateur de chargement
                                uploadBtn.classList.add('fr-btn--loading');
                                uploadBtn.disabled = true;
                                
                                try {
                                    // Convertir le fichier en base64 pour l'envoyer
                                    const reader = new FileReader();
                                    reader.onload = async function(e) {
                                        const base64Data = e.target.result.split(',')[1];
                                        
                                        // Envoyer les données au serveur via AJAX
                                        const response = await fetch('{{ path("upload_pdf") }}', {
                                            method: 'POST',
                                            headers: {
                                                'Content-Type': 'application/json',
                                                'X-Requested-With': 'XMLHttpRequest'
                                            },
                                            body: JSON.stringify({
                                                eleve_id: '{{ app.user.id }}',
                                                document_type: docType,
                                                file_data: base64Data,
                                                file_name: file.name,
                                                file_type: file.type
                                            })
                                        });
                                        
                                        const result = await response.json();
                                        
                                        if (result.success) {
                                            showAlert('Document enregistré avec succès', 'success');
                                            // Recharger la page pour afficher le nouveau document
                                            setTimeout(() => window.location.reload(), 1500);
                                        } else {
                                            showAlert(result.error || 'Erreur lors de l\'enregistrement', 'error');
                                        }
                                    };
                                    reader.readAsDataURL(file);
                                } catch (error) {
                                    showAlert('Erreur lors de l\'upload: ' + error.message, 'error');
                                } finally {
                                    uploadBtn.classList.remove('fr-btn--loading');
                                    uploadBtn.disabled = false;
                                }
                            });
                            
                            // Gestion des boutons "Remplacer"
                            document.querySelectorAll('.replace-btn').forEach(btn => {
                                btn.addEventListener('click', function() {
                                    const docType = this.getAttribute('data-doc-type');
                                    docTypeSelect.value = docType;
                                    // Scroll vers le champ d'upload
                                    docTypeSelect.scrollIntoView({ behavior: 'smooth' });
                                });
                            });
                            
                            function showAlert(message, type) {
                                const alertDiv = document.createElement('div');
                                alertDiv.className = `fr-alert fr-alert--${type} fr-mt-2w`;
                                alertDiv.innerHTML = `
                                    <p class="fr-alert__title">${type === 'success' ? 'Succès' : 'Erreur'}</p>
                                    <p>${message}</p>
                                `;
                                
                                const container = document.getElementById('ajax-messages');
                                container.innerHTML = '';
                                container.appendChild(alertDiv);
                            }
                        });
                    </script>
                {% endif %}

                {% if flow.currentStepNumber == 10 %}
                    <fieldset class="fr-fieldset">
                        <legend class="fr-fieldset__legend fr-text--regular">
                            <span class="fr-icon-check-line fr-icon--sm" aria-hidden="true"></span>
                            Finalisation et adhésion
                        </legend>
                        <div class="fr-fieldset__content">
                            <h4 class="fr-h4">Documents complémentaires</h4>
                            <div class="fr-grid-row fr-grid-row--gutters">
                                <div class="fr-col-12 fr-col-md-6">
                                    {{ form_row(form.cheque) }}
                                </div>
                                <div class="fr-col-12 fr-col-md-6">
                                    {{ form_row(form.droitImage) }}
                                </div>
                            </div>
                            
                            <h4 class="fr-h4 fr-mt-3w">Adhésion</h4>
                            {{ form_row(form.adhesionAccepted) }}
                            {{ form_row(form.adhesionPaymentMethod) }}
                            {{ form_row(form.adhesionImageRights) }}
                        </div>
                    </fieldset>
                    
                    <!-- Message d'information pour l'étape finale -->
                    <div class="fr-alert fr-alert--info fr-mt-2w">
                        <p class="fr-alert__title">Information importante</p>
                        <p>Vous êtes sur le point de finaliser votre inscription. Vérifiez bien toutes les informations saisies avant de valider.</p>
                    </div>
                {% endif %}

                    <div class="fr-mt-4w">
                        <ul class="fr-btns-group fr-btns-group--inline-reverse fr-btns-group--inline-lg">
                            <li>
                                {% if flow.currentStepNumber < 10 %}
                                    <button type="submit" name="flow_transition" value="next" class="fr-btn" id="next-btn">
                                        Étape suivante
                                        <span class="fr-icon-arrow-right-line fr-icon--sm" aria-hidden="true"></span>
                                        <span class="loading-spinner">⏳</span>
                                    </button>
                                {% else %}
                                    <button type="submit" name="flow_transition" value="finish" class="fr-btn fr-btn--icon-left fr-icon-check-line" id="finish-btn">
                                        Valider l'inscription
                                        <span class="loading-spinner">⏳</span>
                                    </button>
                                {% endif %}
                            </li>
                            {% if flow.currentStepNumber > 1 %}
                                <li>
                                    <button type="submit" name="flow_transition" value="previous" class="fr-btn fr-btn--secondary" id="previous-btn">
                                        <span class="fr-icon-arrow-left-line fr-icon--sm" aria-hidden="true"></span>
                                        Étape précédente
                                    </button>
                                </li>
                            {% endif %}
                        </ul>
                    </div>
                {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('inscription-form');
    
    if (!form) {
        console.error('Formulaire inscription-form non trouvé');
        return;
    }

    form.addEventListener('submit', function(event) {
        event.preventDefault();

        // Trouver le bouton qui a été cliqué
        const clickedButton = [...form.querySelectorAll('button[type="submit"]')]
            .find(btn => btn === document.activeElement);
        
        if (!clickedButton) {
            console.warn('Aucun bouton de soumission détecté');
            return;
        }

        // Validation spéciale pour l'étape 10
        if (clickedButton.value === 'finish') {
            if (!validateFinalStep()) {
                return;
            }
        }

        // Préparer les données du formulaire
        const formData = new FormData(form);
        formData.append(clickedButton.name, clickedButton.value);

        // Désactiver le bouton pendant l'envoi
        setButtonLoading(clickedButton, true);

        // Effacer les erreurs précédentes
        clearMessages();

        fetch(form.action, {
            method: 'POST',
            body: formData,
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => {
            if (!response.ok) {
                throw new Error(`Erreur HTTP: ${response.status}`);
            }
            return response.json();
        })
        .then(data => {
            if (data.success) {
                // Succès
                if (data.message) {
                    showMessage('success', data.message);
                }
                
                if (data.redirect) {
                    // Délai court pour permettre à l'utilisateur de voir le message
                    setTimeout(() => {
                        window.location.href = data.redirect;
                    }, 1000);
                } else {
                    console.error('Pas d\'URL de redirection fournie');
                    showMessage('error', 'Succès mais pas de redirection définie');
                }
            } else {
                // Échec - afficher les erreurs
                handleErrors(data);
            }
        })
        .catch(error => {
            console.error('Erreur AJAX :', error);
            showMessage('error', 'Une erreur de connexion est survenue. Veuillez réessayer.');
        })
        .finally(() => {
            // Réactiver le bouton
            setButtonLoading(clickedButton, false);
        });
    });

    /**
     * Validation spécifique pour l'étape finale
     */
    function validateFinalStep() {
        const requiredFields = form.querySelectorAll('[required]');
        let isValid = true;
        
        requiredFields.forEach(field => {
            if (!field.value.trim()) {
                isValid = false;
                field.classList.add('fr-input--error');
            } else {
                field.classList.remove('fr-input--error');
            }
        });
        
        if (!isValid) {
            showMessage('error', 'Veuillez remplir tous les champs obligatoires avant de finaliser votre inscription.');
            return false;
        }
        
        return true;
    }

    /**
     * Gère l'état de chargement des boutons
     */
    function setButtonLoading(button, loading) {
        if (loading) {
            button.disabled = true;
            button.classList.add('fr-btn--loading');
            button.setAttribute('aria-busy', 'true');
        } else {
            button.disabled = false;
            button.classList.remove('fr-btn--loading');
            button.removeAttribute('aria-busy');
        }
    }

    /**
     * Affiche un message (succès ou erreur)
     */
    function showMessage(type, message) {
        const container = document.getElementById('ajax-messages');
        const alertClass = type === 'success' ? 'fr-alert--success' : 'fr-alert--error';
        const alertTitle = type === 'success' ? 'Succès' : 'Erreur';
        
        container.innerHTML = `
            <div class="fr-alert ${alertClass}">
                <p class="fr-alert__title">${alertTitle}</p>
                <p>${message}</p>
            </div>
        `;
        
        // Scroll vers le message
        container.scrollIntoView({ behavior: 'smooth' });
    }

    /**
     * Gère l'affichage des erreurs selon le type de réponse du contrôleur
     */
    function handleErrors(data) {
        if (data.errors && Array.isArray(data.errors)) {
            // Erreurs de validation - les afficher
            displayValidationErrors(data.errors);
        } else if (data.form_html) {
            // Le contrôleur renvoie le HTML du formulaire avec les erreurs
            updateFormContent(data.form_html);
        } else if (data.error) {
            // Message d'erreur simple
            showMessage('error', data.error);
        } else {
            // Erreur générique
            showMessage('error', 'Une erreur est survenue lors du traitement du formulaire.');
        }
    }

    /**
     * Affiche les erreurs de validation de manière accessible
     */
    function displayValidationErrors(errors) {
        let errorMessages = '';
        
        if (errors.length === 1) {
            errorMessages = errors[0];
        } else {
            errorMessages = '<ul>';
            errors.forEach(error => {
                errorMessages += `<li>${error}</li>`;
            });
            errorMessages += '</ul>';
        }
        
        const container = document.getElementById('ajax-messages');
        container.innerHTML = `
            <div class="fr-alert fr-alert--error">
                <p class="fr-alert__title">Erreurs de validation</p>
                <div>${errorMessages}</div>
            </div>
        `;
        
        container.scrollIntoView({ behavior: 'smooth' });
    }

    /**
     * Met à jour le contenu du formulaire avec la version contenant les erreurs
     */
    function updateFormContent(formHtml) {
        const tempDiv = document.createElement('div');
        tempDiv.innerHTML = formHtml;
        
        const newFormContent = tempDiv.querySelector('#inscription-form');
        if (newFormContent) {
            // Sauvegarder les données du formulaire actuel
            const currentData = new FormData(form);
            
            // Remplacer le contenu
            form.innerHTML = newFormContent.innerHTML;
            
            // Restaurer les données si possible
            restoreFormData(currentData);
            
            // Réattacher les event listeners
            reattachEventListeners();
        }
    }

    /**
     * Restaure les données du formulaire après mise à jour du DOM
     */
    function restoreFormData(formData) {
        for (let [name, value] of formData.entries()) {
            const field = form.querySelector(`[name="${name}"]`);
            if (field) {
                if (field.type !== 'file') {
                    field.value = value;
                }
            }
        }
    }

    /**
     * Efface les messages précédents
     */
    function clearMessages() {
        const container = document.getElementById('ajax-messages');
        container.innerHTML = '';
        
        // Effacer les classes d'erreur sur les champs
        const invalidFields = form.querySelectorAll('.fr-input--error, .is-invalid');
        invalidFields.forEach(field => {
            field.classList.remove('fr-input--error', 'is-invalid');
        });
    }

    /**
     * Réattache les event listeners après mise à jour du DOM
     */
    function reattachEventListeners() {
        // Réattacher l'event listener principal
        form.removeEventListener('submit', arguments.callee);
        form.addEventListener('submit', arguments.callee);
        
        console.log('Event listeners réattachés');
    }

    // Gestion de la sauvegarde automatique (désactivée pour l'étape 10)
    let autoSaveTimeout;
    
    function autoSave() {
        // Ne pas sauvegarder automatiquement à l'étape 10
        const currentStep = parseInt(document.querySelector('[data-fr-current-step]')?.getAttribute('data-fr-current-step') || '1');
        if (currentStep === 10) {
            return;
        }
        
        clearTimeout(autoSaveTimeout);
        autoSaveTimeout = setTimeout(() => {
            const formData = new FormData(form);
            formData.append('auto_save', '1');
            
            fetch(form.action, {
                method: 'POST',
                body: formData,
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    console.log('Sauvegarde automatique réussie');
                }
            })
            .catch(error => {
                console.log('Erreur sauvegarde automatique:', error);
            });
        }, 3000); // 3 secondes d'inactivité
    }

    // Activer la sauvegarde automatique sur les changements de champs
    form.addEventListener('input', autoSave);
    form.addEventListener('change', autoSave);
    
    // Confirmation avant de quitter la page à l'étape 10
    window.addEventListener('beforeunload', function(e) {
        const currentStep = parseInt(document.querySelector('[data-fr-current-step]')?.getAttribute('data-fr-current-step') || '1');
        if (currentStep === 10) {
            const confirmationMessage = 'Vous êtes sur le point de quitter la page. Vos données non sauvegardées seront perdues.';
            e.returnValue = confirmationMessage;
            return confirmationMessage;
        }
    });
});
</script>
{% endblock %}