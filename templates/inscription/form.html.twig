                            </div>
                            <div class="fr-grid-row fr-grid-row-gutters">
                                <div class="fr-col-12 fr-col-md-6">
                                    {{ form_row(form.lvDeuxPrecedente2) }}
                                </div>
                                <div class="fr-col-12 fr-col-md-6">
                                    {{ form_row(form.optionPrecedente2) }}
                                </div>
                            </div>
                        </div>
                    </fieldset>
                {% endif %}

                {% if flow.currentStepNumber == 7 %}
                    <fieldset class="fr-fieldset">
                        <legend class="fr-fieldset__legend fr-text--regular">
                            <span class="fr-icon-heart-pulse-line fr-icon--sm" aria-hidden="true"></span>
                            Informations médicales
                        </legend>
                        <div class="fr-fieldset__content">
                            <h4 class="fr-h4">Médecin traitant</h4>
                            <div class="fr-grid-row fr-grid-row--gutters">
                                <div class="fr-col-12 fr-col-md-6">
