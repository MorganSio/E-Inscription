{% extends 'base.html.twig' %} 

{% block title %}Tableau de bord - E-Inscription{% endblock %}

{% block body %}
<div class="fr-container">
    <!-- En-tête avec statut -->
    <div class="fr-grid-row fr-grid-row--gutters">
        <div class="fr-col-12">
            <div class="fr-mb-4w">
                <h1 class="fr-h1">
                    <span class="fr-icon-dashboard-line fr-icon--lg" aria-hidden="true"></span>
                    Tableau de bord
                </h1>
                <div class="fr-badge-group">
                    {% if inscription.isComplete %}
                        <p class="fr-badge fr-badge--success fr-badge--sm">
                            <span class="fr-icon-checkbox-circle-line fr-icon--sm" aria-hidden="true"></span>
                            Dossier complet
                        </p>
                    {% else %}
                        <p class="fr-badge fr-badge--warning fr-badge--sm">
                            <span class="fr-icon-warning-line fr-icon--sm" aria-hidden="true"></span>
                            Dossier incomplet
                        </p>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <div class="fr-grid-row fr-grid-row--gutters">
        <!-- Colonne principale -->
        <div class="fr-col-12 fr-col-lg-8">
            
            <!-- Informations personnelles -->
            <div class="fr-container--fluid fr-py-4w fr-px-3w fr-mb-4w" style="border: 1px solid var(--border-default-grey); border-radius: 8px; background-color: var(--background-default-grey);">
                <h3 class="fr-h3 fr-mb-3w">
                    <span class="fr-icon-user-line fr-icon--sm" aria-hidden="true"></span>
                    Informations personnelles
                </h3>
                {% if inscription.nom is defined and inscription.prenom is defined %}
                    <dl class="fr-dl fr-dl--inline">
                        <dt>Nom :</dt>
                        <dd><strong>{{ inscription.nom }} {{ inscription.prenom }}</strong></dd>
                        
                        {% if inscription.dateNaissance %}
                            <dt>Date de naissance :</dt>
                            <dd>{{ inscription.dateNaissance|date('d/m/Y') }}</dd>
                        {% endif %}
                        
                        {% if inscription.email %}
                            <dt>Email :</dt>
                            <dd><a href="mailto:{{ inscription.email }}" class="fr-link">{{ inscription.email }}</a></dd>
                        {% endif %}
                        
                        {% if inscription.numeroMobile %}
                            <dt>Téléphone mobile :</dt>
                            <dd><a href="tel:{{ inscription.numeroMobile }}" class="fr-link">{{ inscription.numeroMobile }}</a></dd>
                        {% endif %}
                        
                        {% if inscription.classe and inscription.classe.label %}
                            <dt>Classe :</dt>
                            <dd><span class="fr-badge fr-badge--blue-cumulus">{{ inscription.classe.label }}</span></dd>
                        {% else %}
                            <dt>Classe :</dt>
                            <dd><span class="fr-text--muted">
                                <span class="fr-icon-warning-line fr-icon--sm" aria-hidden="true"></span>
                                Non renseignée
                            </span></dd>
                        {% endif %}
                        
                        {% if inscription.promotion %}
                            <dt>Promotion :</dt>
                            <dd>{{ inscription.promotion }}</dd>
                        {% endif %}
                        
                        {% if inscription.nationalite %}
                            <dt>Nationalité :</dt>
                            <dd>{{ inscription.nationalite }}</dd>
                        {% endif %}
                        
                        {% if inscription.departement %}
                            <dt>Département :</dt>
                            <dd>{{ inscription.departement }}</dd>
                        {% endif %}
                        
                        {% if inscription.communeNaissance %}
                            <dt>Commune de naissance :</dt>
                            <dd>{{ inscription.communeNaissance }}</dd>
                        {% endif %}
                        
                        {% if inscription.sexe %}
                            <dt>Sexe :</dt>
                            <dd>{{ inscription.sexe }}</dd>
                        {% endif %}
                        
                        {% if inscription.regime %}
                            <dt>Régime :</dt>
                            <dd>{{ inscription.regime }}</dd>
                        {% endif %}
                    </dl>
                {% else %}
                    <div class="fr-alert fr-alert--info fr-alert--sm">
                        <p>Informations personnelles non renseignées</p>
                    </div>
                {% endif %}
            </div>

            <!-- Représentants légaux -->
            <div class="fr-container--fluid fr-py-4w fr-px-3w fr-mb-4w" style="border: 1px solid var(--border-default-grey); border-radius: 8px; background-color: var(--background-default-grey);">
                <h3 class="fr-h3 fr-mb-3w">
                    <span class="fr-icon-group-line fr-icon--sm" aria-hidden="true"></span>
                    Représentants légaux
                </h3>
                {% if inscription.representantLegal1Nom is defined %}
                    <div class="fr-mb-3w">
                        <h4 class="fr-h6">Représentant légal 1</h4>
                        <dl class="fr-dl fr-dl--inline">
                            <dt>Nom :</dt>
                            <dd><strong>{{ inscription.representantLegal1Nom }} {{ inscription.representantLegal1Prenom }}</strong></dd>
                            
                            {% if inscription.representantLegal1Courriel %}
                                <dt>Email :</dt>
                                <dd><a href="mailto:{{ inscription.representantLegal1Courriel }}" class="fr-link">{{ inscription.representantLegal1Courriel }}</a></dd>
                            {% endif %}
                            
                            {% if inscription.representantLegal1Telephone %}
                                <dt>Tél. personnel :</dt>
                                <dd><a href="tel:{{ inscription.representantLegal1Telephone }}" class="fr-link">{{ inscription.representantLegal1Telephone }}</a></dd>
                            {% endif %}
                            
                            {% if inscription.representantLegal1TelephoneFixe %}
                                <dt>Tél. fixe :</dt>
                                <dd><a href="tel:{{ inscription.representantLegal1TelephoneFixe }}" class="fr-link">{{ inscription.representantLegal1TelephoneFixe }}</a></dd>
                            {% endif %}
                            
                            {% if inscription.representantLegal1TelephonePro %}
                                <dt>Tél. professionnel :</dt>
                                <dd><a href="tel:{{ inscription.representantLegal1TelephonePro }}" class="fr-link">{{ inscription.representantLegal1TelephonePro }}</a></dd>
                            {% endif %}
                            
                            {% if inscription.representantLegal1Adresse %}
                                <dt>Adresse :</dt>
                                <dd>{{ inscription.representantLegal1Adresse }}, {{ inscription.representantLegal1CodePostal }} {{ inscription.representantLegal1Commune }}</dd>
                            {% endif %}
                            
                            {% if inscription.representantLegal1LienEleve %}
                                <dt>Lien avec l'élève :</dt>
                                <dd>{{ inscription.representantLegal1LienEleve }}</dd>
                            {% endif %}
                            
                            {% if inscription.representantLegal1Poste %}
                                <dt>Poste :</dt>
                                <dd>{{ inscription.representantLegal1Poste }}</dd>
                            {% endif %}
                            
                            {% if inscription.representantLegal1NomEmployeur %}
                                <dt>Employeur :</dt>
                                <dd>{{ inscription.representantLegal1NomEmployeur }}</dd>
                            {% endif %}
                            
                            {% if inscription.representantLegal1AdresseEmployeur %}
                                <dt>Adresse employeur :</dt>
                                <dd>{{ inscription.representantLegal1AdresseEmployeur }}</dd>
                            {% endif %}
                        </dl>
                    </div>
                {% endif %}
                
                {% if inscription.representantLegal2Nom is defined %}
                    <div class="fr-mb-3w">
                        <h4 class="fr-h6">Représentant légal 2</h4>
                        <dl class="fr-dl fr-dl--inline">
                            <dt>Nom :</dt>
                            <dd><strong>{{ inscription.representantLegal2Nom }} {{ inscription.representantLegal2Prenom }}</strong></dd>
                            
                            {% if inscription.representantLegal2Courriel %}
                                <dt>Email :</dt>
                                <dd><a href="mailto:{{ inscription.representantLegal2Courriel }}" class="fr-link">{{ inscription.representantLegal2Courriel }}</a></dd>
                            {% endif %}
                            
                            {% if inscription.representantLegal2Telephone %}
                                <dt>Tél. personnel :</dt>
                                <dd><a href="tel:{{ inscription.representantLegal2Telephone }}" class="fr-link">{{ inscription.representantLegal2Telephone }}</a></dd>
                            {% endif %}
                            
                            {% if inscription.representantLegal2TelephoneFixe %}
                                <dt>Tél. fixe :</dt>
                                <dd><a href="tel:{{ inscription.representantLegal2TelephoneFixe }}" class="fr-link">{{ inscription.representantLegal2TelephoneFixe }}</a></dd>
                            {% endif %}
                            
                            {% if inscription.representantLegal2TelephonePro %}
                                <dt>Tél. professionnel :</dt>
                                <dd><a href="tel:{{ inscription.representantLegal2TelephonePro }}" class="fr-link">{{ inscription.representantLegal2TelephonePro }}</a></dd>
                            {% endif %}
                            
                            {% if inscription.representantLegal2Adresse %}
                                <dt>Adresse :</dt>
                                <dd>{{ inscription.representantLegal2Adresse }}, {{ inscription.representantLegal2CodePostal }} {{ inscription.representantLegal2Commune }}</dd>
                            {% endif %}
                            
                            {% if inscription.representantLegal2LienEleve %}
                                <dt>Lien avec l'élève :</dt>
                                <dd>{{ inscription.representantLegal2LienEleve }}</dd>
                            {% endif %}
                            
                            {% if inscription.representantLegal2Poste %}
                                <dt>Poste :</dt>
                                <dd>{{ inscription.representantLegal2Poste }}</dd>
                            {% endif %}
                            
                            {% if inscription.representantLegal2NomEmployeur %}
                                <dt>Employeur :</dt>
                                <dd>{{ inscription.representantLegal2NomEmployeur }}</dd>
                            {% endif %}
                            
                            {% if inscription.representantLegal2AdresseEmployeur %}
                                <dt>Adresse employeur :</dt>
                                <dd>{{ inscription.representantLegal2AdresseEmployeur }}</dd>
                            {% endif %}
                        </dl>
                    </div>
                {% endif %}

                {% if not inscription.representantLegal1Nom is defined and not inscription.representantLegal2Nom is defined %}
                    <div class="fr-alert fr-alert--info fr-alert--sm">
                        <p>Informations des représentants légaux non renseignées</p>
                    </div>
                {% endif %}
            </div>

            <!-- Scolarité précédente -->
            <div class="fr-container--fluid fr-py-4w fr-px-3w fr-mb-4w" style="border: 1px solid var(--border-default-grey); border-radius: 8px; background-color: var(--background-default-grey);">
                <h3 class="fr-h3 fr-mb-3w">
                    <span class="fr-icon-school-line fr-icon--sm" aria-hidden="true"></span>
                    Scolarité précédente
                </h3>
                {% if inscription.scolariteUnEtablissement is defined %}
                    <div class="fr-mb-3w">
                        <h4 class="fr-h6">Année scolaire précédente 1 (N-1)</h4>
                        <dl class="fr-dl fr-dl--inline">
                            <dt>Établissement :</dt>
                            <dd>{{ inscription.scolariteUnEtablissement }}</dd>
                            <dt>Classe :</dt>
                            <dd>{{ inscription.scolariteUnClasse }}</dd>
                            <dt>Option :</dt>
                            <dd>{{ inscription.scolariteUnOption }}</dd>
                            <dt>Langue vivante 1 :</dt>
                            <dd>{{ inscription.scolariteUnLVUn }}</dd>
                            <dt>Langue vivante 2 :</dt>
                            <dd>{{ inscription.scolariteUnLVDeux }}</dd>
                            <dt>Année scolaire :</dt>
                            <dd>{{ inscription.scolariteUnAnnee }}</dd>
                        </dl>
                    </div>
                {% else %}
                    <div class="fr-alert fr-alert--info fr-alert--sm fr-mb-3w">
                        <p>Aucune scolarité précédente renseignée pour l'année N-1</p>
                    </div>
                {% endif %}
                
                {% if inscription.scolariteDeuxEtablissement is defined %}
                    <div class="fr-mb-3w">
                        <h4 class="fr-h6">Année scolaire précédente 2 (N-2)</h4>
                        <dl class="fr-dl fr-dl--inline">
                            <dt>Établissement :</dt>
                            <dd>{{ inscription.scolariteDeuxEtablissement }}</dd>
                            <dt>Classe :</dt>
                            <dd>{{ inscription.scolariteDeuxClasse }}</dd>
                            <dt>Option :</dt>
                            <dd>{{ inscription.scolariteDeuxOption }}</dd>
                            <dt>Langue vivante 1 :</dt>
                            <dd>{{ inscription.scolariteDeuxLVUn }}</dd>
                            <dt>Langue vivante 2 :</dt>
                            <dd>{{ inscription.scolariteDeuxLVDeux }}</dd>
                            <dt>Année scolaire :</dt>
                            <dd>{{ inscription.scolariteDeuxAnnee }}</dd>
                        </dl>
                    </div>
                {% else %}
                    <div class="fr-alert fr-alert--info fr-alert--sm">
                        <p>Aucune scolarité précédente renseignée pour l'année N-2</p>
                    </div>
                {% endif %}
            </div>

            <!-- Informations médicales -->
            <div class="fr-container--fluid fr-py-4w fr-px-3w fr-mb-4w" style="border: 1px solid var(--border-default-grey); border-radius: 8px; background-color: var(--background-default-grey);">
                <h3 class="fr-h3 fr-mb-3w">
                    <span class="fr-icon-heart-pulse-line fr-icon--sm" aria-hidden="true"></span>
                    Informations médicales
                </h3>
                {% if inscription.medecinTraitantNom is defined %}
                    <div class="fr-mb-3w">
                        <h4 class="fr-h6">Médecin traitant</h4>
                        <dl class="fr-dl fr-dl--inline">
                            <dt>Nom :</dt>
                            <dd>{{ inscription.medecinTraitantNom }}</dd>
                            {% if inscription.medecinTraitantTelephone %}
                                <dt>Téléphone :</dt>
                                <dd><a href="tel:{{ inscription.medecinTraitantTelephone }}" class="fr-link">{{ inscription.medecinTraitantTelephone }}</a></dd>
                            {% endif %}
                            {% if inscription.medecinTraitantAdresse %}
                                <dt>Adresse :</dt>
                                <dd>{{ inscription.medecinTraitantAdresse }}</dd>
                            {% endif %}
                        </dl>
                    </div>
                {% endif %}
                
                {% if inscription.dernierRappelAntitetanique is defined %}
                    <dl class="fr-dl fr-dl--inline fr-mb-2w">
                        <dt>Dernier rappel antitétanique :</dt>
                        <dd>{{ inscription.dernierRappelAntitetanique|date('d/m/Y') }}</dd>
                    </dl>
                {% endif %}
                
                {% if inscription.numSecuSocial is defined %}
                    <dl class="fr-dl fr-dl--inline fr-mb-2w">
                        <dt>Numéro de sécurité sociale :</dt>
                        <dd>{{ inscription.numSecuSocial }}</dd>
                    </dl>
                {% endif %}
                
                {% if inscription.secuSocialeNom is defined %}
                    <div class="fr-mb-3w">
                        <h4 class="fr-h6">Sécurité sociale</h4>
                        <dl class="fr-dl fr-dl--inline">
                            <dt>Nom :</dt>
                            <dd>{{ inscription.secuSocialeNom }}</dd>
                            {% if inscription.secuSocialeAdresse %}
                                <dt>Adresse :</dt>
                                <dd>{{ inscription.secuSocialeAdresse }}</dd>
                            {% endif %}
                        </dl>
                    </div>
                {% endif %}
                
                {% if inscription.assureurNom is defined %}
                    <div class="fr-mb-3w">
                        <h4 class="fr-h6">Assureur</h4>
                        <dl class="fr-dl fr-dl--inline">
                            <dt>Nom :</dt>
                            <dd>{{ inscription.assureurNom }}</dd>
                            {% if inscription.assureurNumeroAssurance %}
                                <dt>Numéro d'assurance :</dt>
                                <dd>{{ inscription.assureurNumeroAssurance }}</dd>
                            {% endif %}
                            {% if inscription.assureurAdresse %}
                                <dt>Adresse :</dt>
                                <dd>{{ inscription.assureurAdresse }}</dd>
                            {% endif %}
                        </dl>
                    </div>
                {% endif %}
                
                {% if inscription.medecinTraitantNom is not defined and inscription.secuSocialeNom is not defined and inscription.assureurNom is not defined %}
                    <div class="fr-alert fr-alert--info fr-alert--sm">
                        <p>Informations médicales non renseignées</p>
                    </div>
                {% endif %}
            </div>

            <!-- Informations financières -->
            <div class="fr-container--fluid fr-py-4w fr-px-3w fr-mb-4w" style="border: 1px solid var(--border-default-grey); border-radius: 8px; background-color: var(--background-default-grey);">
                <h3 class="fr-h3 fr-mb-3w">
                    <span class="fr-icon-money-euro-circle-line fr-icon--sm" aria-hidden="true"></span>
                    Informations financières
                </h3>
                {% if inscription.responsableFinancierNom is defined %}
                    <dl class="fr-dl fr-dl--inline">
                        <dt>Responsable financier :</dt>
                        <dd><strong>{{ inscription.responsableFinancierNom }} {{ inscription.responsableFinancierPrenom }}</strong></dd>
                        {% if inscription.responsableFinancierNomEmployeur %}
                            <dt>Employeur :</dt>
                            <dd>{{ inscription.responsableFinancierNomEmployeur }}</dd>
                        {% endif %}
                        {% if inscription.responsableFinancierAdresseEmployeur %}
                            <dt>Adresse employeur :</dt>
                            <dd>{{ inscription.responsableFinancierAdresseEmployeur }}</dd>
                        {% endif %}
                    </dl>
                {% else %}
                    <div class="fr-alert fr-alert--info fr-alert--sm">
                        <p>Informations financières non renseignées</p>
                    </div>
                {% endif %}
            </div>

            <!-- Documents à fournir -->
            <div class="fr-container--fluid fr-py-4w fr-px-3w fr-mb-4w" style="border: 1px solid var(--border-default-grey); border-radius: 8px; background-color: var(--background-default-grey);">
                <h3 class="fr-h3 fr-mb-3w">
                    <span class="fr-icon-file-text-line fr-icon--sm" aria-hidden="true"></span>
                    Documents à fournir
                </h3>
                <div class="fr-grid-row fr-grid-row--gutters">
                    <div class="fr-col-12 fr-col-md-6">
                        <div class="fr-checkbox-group">
                            <input type="checkbox" id="carte-vitale" name="carte-vitale" disabled {{ inscription.carteVitale is defined and inscription.carteVitale ? 'checked' : '' }}>
                            <label class="fr-label" for="carte-vitale">
                                Carte Vitale
                                {% if inscription.carteVitale is defined and inscription.carteVitale %}
                                    <span class="fr-icon-checkbox-circle-fill fr-icon--sm" style="color: var(--success-425-625);" aria-hidden="true"></span>
                                {% endif %}
                            </label>
                        </div>
                        <div class="fr-checkbox-group">
                            <input type="checkbox" id="photo-identite" name="photo-identite" disabled {{ inscription.photoIdentite is defined and inscription.photoIdentite ? 'checked' : '' }}>
                            <label class="fr-label" for="photo-identite">
                                Photo d'identité
                                {% if inscription.photoIdentite is defined and inscription.photoIdentite %}
                                    <span class="fr-icon-checkbox-circle-fill fr-icon--sm" style="color: var(--success-425-625);" aria-hidden="true"></span>
                                {% endif %}
                            </label>
                        </div>
                        <div class="fr-checkbox-group">
                            <input type="checkbox" id="attestation-identite" name="attestation-identite" disabled {{ inscription.attestationIdentite is defined and inscription.attestationIdentite ? 'checked' : '' }}>
                            <label class="fr-label" for="attestation-identite">
                                Attestation d'identité
                                {% if inscription.attestationIdentite is defined and inscription.attestationIdentite %}
                                    <span class="fr-icon-checkbox-circle-fill fr-icon--sm" style="color: var(--success-425-625);" aria-hidden="true"></span>
                                {% endif %}
                            </label>
                        </div>
                    </div>
                    <div class="fr-col-12 fr-col-md-6">
                        <div class="fr-checkbox-group">
                            <input type="checkbox" id="bourse" name="bourse" disabled {{ inscription.bourse is defined and inscription.bourse ? 'checked' : '' }}>
                            <label class="fr-label" for="bourse">
                                Bourse
                                {% if inscription.bourse is defined and inscription.bourse %}
                                    <span class="fr-icon-checkbox-circle-fill fr-icon--sm" style="color: var(--success-425-625);" aria-hidden="true"></span>
                                {% endif %}
                            </label>
                        </div>
                        <div class="fr-checkbox-group">
                            <input type="checkbox" id="attestation-jdc" name="attestation-jdc" disabled {{ inscription.attestationJDC is defined and inscription.attestationJDC ? 'checked' : '' }}>
                            <label class="fr-label" for="attestation-jdc">
                                Attestation JDC
                                {% if inscription.attestationJDC is defined and inscription.attestationJDC %}
                                    <span class="fr-icon-checkbox-circle-fill fr-icon--sm" style="color: var(--success-425-625);" aria-hidden="true"></span>
                                {% endif %}
                            </label>
                        </div>
                        <div class="fr-checkbox-group">
                            <input type="checkbox" id="attestation-reussite" name="attestation-reussite" disabled {{ inscription.attestationReusite is defined and inscription.attestationReusite ? 'checked' : '' }}>
                            <label class="fr-label" for="attestation-reussite">
                                Attestation de réussite
                                {% if inscription.attestationReusite is defined and inscription.attestationReusite %}
                                    <span class="fr-icon-checkbox-circle-fill fr-icon--sm" style="color: var(--success-425-625);" aria-hidden="true"></span>
                                {% endif %}
                            </label>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Colonne latérale -->
        <div class="fr-col-12 fr-col-lg-4">
            
            <!-- Actions rapides -->
            <div class="fr-container--fluid fr-py-4w fr-px-3w fr-mb-4w" style="border: 1px solid var(--border-default-grey); border-radius: 8px; background-color: var(--background-default-grey);">
                <h3 class="fr-h3 fr-mb-3w">
                    <span class="fr-icon-settings-5-line fr-icon--sm" aria-hidden="true"></span>
                    Actions rapides
                </h3>
                <ul class="fr-btns-group fr-btns-group--vertical fr-btns-group--icon-left">
                    {% if inscription %}
                        <li>
                            <a class="fr-btn fr-btn--primary fr-icon-edit-line" href="{{ path('app_inscription_form', {'step': 1}) }}">
                                Modifier mon inscription
                            </a>
                        </li>
                    {% endif %}
                    <li>
                        <a class="fr-btn fr-btn--secondary fr-icon-refresh-line" 
                           href="{{ path('app_inscription_form', {'step': 1}) }}" 
                           onclick="return confirm('Êtes-vous sûr ? Vous allez recommencer votre inscription depuis le début.')">
                            Recommencer l'inscription
                        </a>
                    </li>
                </ul>
            </div>

            <!-- Informations complémentaires -->
            <div class="fr-container--fluid fr-py-4w fr-px-3w fr-mb-4w" style="border: 1px solid var(--border-default-grey); border-radius: 8px; background-color: var(--background-default-grey); box-shadow: var(--shadow-lifted);">
                <h3 class="fr-h3 fr-mb-3w">
                    <span class="fr-icon-information-line fr-icon--sm fr-mr-1w" aria-hidden="true"></span>
                    Informations complémentaires
                </h3>
                {% set hasComplementaryInfo = inscription.numeroContacteUrgence is defined or 
                                             inscription.transportScolaire is defined or 
                                             inscription.lvUn is defined or 
                                             inscription.lvDeux is defined or 
                                             inscription.dernierDiplome is defined %}
                
                {% if hasComplementaryInfo %}
                    <div class="fr-grid-row fr-grid-row--gutters">
                        {% if inscription.numeroContacteUrgence is defined %}
                            <div class="fr-col-12">
                                <div class="fr-notice fr-notice--info fr-mb-2w">
                                    <div class="fr-container">
                                        <div class="fr-notice__body">
                                            <p class="fr-notice__title">
                                                <span class="fr-icon-phone-line fr-icon--sm fr-mr-1w" aria-hidden="true"></span>
                                                Contact d'urgence
                                            </p>
                                            <div class="fr-notice__desc">
                                                <strong>{{ inscription.nomContacteUrgence }}</strong><br>
                                                <a href="tel:{{ inscription.numeroContacteUrgence }}" 
                                                   class="fr-link fr-link--icon-left fr-icon-phone-line">
                                                    {{ inscription.numeroContacteUrgence }}
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endif %}
                        
                        <div class="fr-col-12 fr-col-md-6">
                            {% if inscription.transportScolaire is defined %}
                                <div class="fr-py-2w fr-px-3w fr-mb-2w" style="border: 1px solid var(--border-default-grey); border-radius: 4px;">
                                    <h4 class="fr-h6">
                                        <span class="fr-icon-bus-line fr-icon--sm fr-mr-1w" aria-hidden="true"></span>
                                        Transport scolaire
                                    </h4>
                                    <p class="fr-text--sm">{{ inscription.transportScolaire }}</p>
                                </div>
                            {% endif %}
                            
                            {% if inscription.dernierDiplome is defined %}
                                <div class="fr-py-2w fr-px-3w fr-mb-2w" style="border: 1px solid var(--border-default-grey); border-radius: 4px;">
                                    <h4 class="fr-h6">
                                        <span class="fr-icon-award-line fr-icon--sm fr-mr-1w" aria-hidden="true"></span>
                                        Dernier diplôme
                                    </h4>
                                    <p class="fr-text--sm">{{ inscription.dernierDiplome }}</p>
                                </div>
                            {% endif %}
                        </div>
                        
                        <div class="fr-col-12 fr-col-md-6">
                            {% if inscription.lvUn is defined or inscription.lvDeux is defined %}
                                <div class="fr-container fr-container--sm fr-enlarge-link fr-mb-2w">
                                    <div class="fr-container__body">
                                        <div class="fr-container__content">
                                            <h4 class="fr-container__title">
                                                <span class="fr-icon-global-line fr-icon--sm fr-mr-1w" aria-hidden="true"></span>
                                                Langues vivantes
                                            </h4>
                                            <div class="fr-container__desc">
                                                {% if inscription.lvUn is defined %}
                                                    <div class="fr-mb-1v">
                                                        <span class="fr-badge fr-badge--blue-cumulus fr-badge--sm">LV1</span>
                                                        <span class="fr-ml-1w">{{ inscription.lvUn }}</span>
                                                    </div>
                                                {% endif %}
                                                {% if inscription.lvDeux is defined %}
                                                    <div>
                                                        <span class="fr-badge fr-badge--purple-glycine fr-badge--sm">LV2</span>
                                                        <span class="fr-ml-1w">{{ inscription.lvDeux }}</span>
                                                    </div>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            {% else %}
                                <div class="fr-alert fr-alert--info fr-alert--sm">
                                    <h4 class="fr-alert__title">Aucune information complémentaire</h4>
                                    <p>Vous pourrez ajouter ces informations en modifiant votre inscription.</p>
                                </div>
                            {% endif %}                            
                        </div>
                    </div>
                {% endif %}
                </div>
            </div>

            <div class="fr-container fr-container--border fr-container--shadow fr-mb-4w">
                <div class="fr-container__body">
                    <div class="fr-container__content">
                        <h3 class="fr-container__title fr-mb-3w">
                            <span class="fr-icon-line-chart-line fr-icon--sm fr-mr-1w" aria-hidden="true"></span>
                            Progression du dossier
                        </h3>
                        <div class="fr-container__desc">
                            {% set totalSteps = 8 %}
                            {% set completedSteps = 0 %}
                            
                            {% if inscription.nom is defined and inscription.prenom is defined %}
                                {% set completedSteps = completedSteps + 1 %}
                            {% endif %}
                            {% if inscription.representantLegal1Nom is defined %}
                                {% set completedSteps = completedSteps + 1 %}
                            {% endif %}
                            {% if inscription.scolariteUnEtablissement is defined %}
                                {% set completedSteps = completedSteps + 1 %}
                            {% endif %}
                            {% if inscription.medecinTraitantNom is defined %}
                                {% set completedSteps = completedSteps + 1 %}
                            {% endif %}
                            {% if inscription.responsableFinancierNom is defined %}
                                {% set completedSteps = completedSteps + 1 %}
                            {% endif %}
                            {% if inscription.carteVitale is defined and inscription.carteVitale %}
                                {% set completedSteps = completedSteps + 1 %}
                            {% endif %}
                            {% if inscription.photoIdentite is defined and inscription.photoIdentite %}
                                {% set completedSteps = completedSteps + 1 %}
                            {% endif %}
                            {% if inscription.attestationIdentite is defined and inscription.attestationIdentite %}
                                {% set completedSteps = completedSteps + 1 %}
                            {% endif %}
                            
                            {% set progressPercent = (completedSteps / totalSteps * 100)|round %}
                            
                            <div class="fr-mb-3w">
                                <div class="fr-text--bold fr-mb-1w">{{ completedSteps }} / {{ totalSteps }} étapes complétées</div>
                                <div class="fr-progress">
                                    <div class="fr-progress__bar" role="progressbar" 
                                        aria-valuenow="{{ progressPercent }}" 
                                        aria-valuemin="0" 
                                        aria-valuemax="100">
                                        <span class="fr-progress__value" style="width: {{ progressPercent }}%"></span>
                                    </div>
                                </div>
                                <div class="fr-text--sm fr-text--muted fr-mt-1v">{{ progressPercent }}% complété</div>
                            </div>
                            
                            <!-- Liste des étapes -->
                            <div class="fr-accordions-group">
                                <section class="fr-accordion">
                                    <h4 class="fr-accordion__title">
                                        <button class="fr-accordion__btn" aria-expanded="false" aria-controls="accordion-details">
                                            Détail des étapes
                                            <span class="fr-icon-arrow-down-s-line fr-accordion__btn-icon" aria-hidden="true"></span>
                                        </button>
                                    </h4>
                                    <div class="fr-collapse" id="accordion-details">
                                        <div class="fr-stepper">
                                            <div class="fr-stepper__steps" data-fr-stepper-current-step="{{ completedSteps }}" data-fr-stepper-steps="{{ totalSteps }}">
                                                <div class="fr-stepper__step {{ inscription.nom is defined and inscription.prenom is defined ? 'fr-stepper__step--current' : '' }}">
                                                    <p class="fr-stepper__title">
                                                        Informations personnelles
                                                        {% if inscription.nom is defined and inscription.prenom is defined %}
                                                            <span class="fr-icon-checkbox-circle-fill fr-ml-1w" style="color: var(--success-425-625);" aria-hidden="true"></span>
                                                        {% endif %}
                                                    </p>
                                                </div>
                                                <div class="fr-stepper__step {{ inscription.representantLegal1Nom is defined ? 'fr-stepper__step--current' : '' }}">
                                                    <p class="fr-stepper__title">
                                                        Représentants légaux
                                                        {% if inscription.representantLegal1Nom is defined %}
                                                            <span class="fr-icon-checkbox-circle-fill fr-ml-1w" style="color: var(--success-425-625);" aria-hidden="true"></span>
                                                        {% endif %}
                                                    </p>
                                                </div>
                                                <div class="fr-stepper__step {{ inscription.scolariteUnEtablissement is defined ? 'fr-stepper__step--current' : '' }}">
                                                    <p class="fr-stepper__title">
                                                        Scolarité précédente
                                                        {% if inscription.scolariteUnEtablissement is defined %}
                                                            <span class="fr-icon-checkbox-circle-fill fr-ml-1w" style="color: var(--success-425-625);" aria-hidden="true"></span>
                                                        {% endif %}
                                                    </p>
                                                </div>
                                                <div class="fr-stepper__step {{ inscription.medecinTraitantNom is defined ? 'fr-stepper__step--current' : '' }}">
                                                    <p class="fr-stepper__title">
                                                        Informations médicales
                                                        {% if inscription.medecinTraitantNom is defined %}
                                                            <span class="fr-icon-checkbox-circle-fill fr-ml-1w" style="color: var(--success-425-625);" aria-hidden="true"></span>
                                                        {% endif %}
                                                    </p>
                                                </div>
                                                <div class="fr-stepper__step {{ inscription.responsableFinancierNom is defined ? 'fr-stepper__step--current' : '' }}">
                                                    <p class="fr-stepper__title">
                                                        Informations financières
                                                        {% if inscription.responsableFinancierNom is defined %}
                                                            <span class="fr-icon-checkbox-circle-fill fr-ml-1w" style="color: var(--success-425-625);" aria-hidden="true"></span>
                                                        {% endif %}
                                                    </p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </section>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Contact et assistance -->
            <div class="fr-container fr-container--border fr-container--shadow">
                <div class="fr-container__body">
                    <div class="fr-container__content">
                        <h3 class="fr-container__title fr-mb-3w">
                            <span class="fr-icon-customer-service-line fr-icon--sm fr-mr-1w" aria-hidden="true"></span>
                            Conseil ?
                        </h3>
                        <div class="fr-container__desc"> 
                            <div class="fr-alert fr-alert--info fr-alert--sm">
                                <p class="fr-alert__desc">
                                    Pensez à sauvegarder régulièrement vos informations pour éviter toute perte de données.
                                </p>
                            </div>
                        </div>
                        <div><p></p></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const progressBar = document.querySelector('.fr-progress__value');
    if (progressBar) {
        const targetWidth = progressBar.style.width;
        progressBar.style.width = '0%';
        setTimeout(() => {
            progressBar.style.transition = 'width 1s ease-in-out';
            progressBar.style.width = targetWidth;
        }, 100);
    }
    
    const accordionButtons = document.querySelectorAll('.fr-accordion__btn');
    accordionButtons.forEach(button => {
        button.addEventListener('click', function() {
            const expanded = this.getAttribute('aria-expanded') === 'true';
            this.setAttribute('aria-expanded', !expanded);
            const collapse = document.getElementById(this.getAttribute('aria-controls'));
            if (collapse) {
                collapse.style.display = expanded ? 'none' : 'block';
            }
        });
    });
});
</script>
{% endblock %}