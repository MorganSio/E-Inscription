            fields: [
                { key: 'nomContacteUrgence', label: 'Nom du contact', searchText: 'Contact d\'urgence' },
                { key: 'numeroContacteUrgence', label: 'Téléphone du contact', searchText: 'Contact d\'urgence' }
            ]
        },
        'scolarite': {
            title: 'Scolarité',
            icon: 'fr-icon-school-line',
            fields: [
                { key: 'classe', label: 'Classe', searchText: 'Classe :' },
                { key: 'promotion', label: 'Promotion', searchText: 'Promotion :' },
                { key: 'regime', label: 'Régime', searchText: 'Régime :' },
                { key: 'redoublant', label: 'Redoublant', searchText: 'Redoublant :' },
                { key: 'lvUn', label: 'Langue vivante 1', searchText: 'Langue vivante 1 :' },
                { key: 'lvDeux', label: 'Langue vivante 2', searchText: 'Langue vivante 2 :' },
                { key: 'dernierDiplome', label: 'Dernier diplôme', searchText: 'Dernier diplôme :' },
                { key: 'transportScolaire', label: 'Transport scolaire', searchText: 'Transport scolaire :' },
                { key: 'immatriculationVeic', label: 'Immatriculation véhicule', searchText: 'Immatriculation véhicule :' }
            ]
        },
        'representant_legal_1': {
            title: 'Représentant légal 1',
            icon: 'fr-icon-group-line',
            fields: [
                { key: 'nom', label: 'Nom', searchText: 'Nom :' },
                { key: 'prenom', label: 'Prénom', searchText: 'Prénom :' },
                { key: 'email', label: 'Email', searchText: 'Email :' },
                { key: 'telephone', label: 'Téléphone', searchText: 'Téléphone :' },
                { key: 'adresse', label: 'Adresse', searchText: 'Adresse :' },
                { key: 'codePostal', label: 'Code postal', searchText: 'Code postal :' },
                { key: 'commune', label: 'Commune', searchText: 'Commune :' },
                { key: 'poste', label: 'Poste', searchText: 'Poste :' },
                { key: 'lienEleve', label: 'Lien avec l\'élève', searchText: 'Lien avec l\'élève :' },
                { key: 'nomEmployeur', label: 'Nom de l\'employeur', searchText: 'Nom de l\'employeur :' },
                { key: 'adresseEmployeur', label: 'Adresse de l\'employeur', searchText: 'Adresse de l\'employeur :' },
                { key: 'sms', label: 'Accepter SMS', searchText: 'Accepter SMS :' }
            ]
        },
        'representant_legal_2': {
            title: 'Représentant légal 2',
            icon: 'fr-icon-group-line',
            fields: [
                { key: 'nom', label: 'Nom', searchText: 'Nom :' },
