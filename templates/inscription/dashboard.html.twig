    // Fonction pour calculer la complétion par section
    function calculateSectionCompletion(sectionKey, sectionConfig) {
        let completedFields = 0;
        let totalFields = sectionConfig.fields.length;
        let completedFieldsList = [];
        let missingFieldsList = [];

        sectionConfig.fields.forEach(field => {
            if (checkFieldCompletion(field)) {
                completedFields++;
                completedFieldsList.push(field);
            } else {
                missingFieldsList.push(field);
            }
        });

        return {
            completed: completedFields,
            total: totalFields,
            percentage: totalFields > 0 ? Math.round((completedFields / totalFields) * 100) : 0,
            completedFields: completedFieldsList,
            missingFields: missingFieldsList
        };
    }

    const totalSteps = Object.keys(sectionsConfig).length;

        // Fonction pour vérifier si un champ est complété
    function checkFieldCompletion(field) {
        // Vérifiez si le champ existe dans l'objet inscription et s'il est défini et non vide
        return inscription[field.key] !== undefined && inscription[field.key] !== null && inscription[field.key] !== '';
    }

    // Calculer la progression totale
    let overallCompletedSteps = 0;

    // Itérer sur chaque section pour calculer la progression
    for (const [key, config] of Object.entries(sectionsConfig)) {
        const completion = calculateSectionCompletion(key, config);
        overallCompletedSteps += completion.completed;
    }

    // Mettre à jour le pourcentage de progression global
    const overallProgressPercent = (overallCompletedSteps / (totalSteps * 10) * 100).toFixed(2); // 10 est le nombre total de champs à vérifier

    // Afficher la progression globale
    console.log(`Progression globale : ${overallProgressPercent}%`);
