{% extends 'base.html.twig' %}

{% block title %}Adhésion à la MDL
{% endblock %}

{% block body %}

	{% for flash_error in app.flashes('verify_email_error') %}
		<div class="fr-alert fr-alert--error" role="alert">{{ flash_error }}</div>
	{% endfor %}

	<script>
		document.addEventListener('DOMContentLoaded', function () {
const radios = document.querySelectorAll('input[name$="[accepted]"]');
const paymentFieldset = document.getElementById('payment-method-fieldset');
const imageRightsFieldset = document.getElementById('image-rights-inline');

function toggleSections() {
const accepted = document.querySelector('input[name$="[accepted]"]:checked');
if (accepted && (accepted.value === "1" || accepted.value === "true")) {
if (paymentFieldset) 
paymentFieldset.style.display = '';

if (imageRightsFieldset) 
imageRightsFieldset.style.display = '';

} else {
if (paymentFieldset) 
paymentFieldset.style.display = 'none';

if (imageRightsFieldset) 
imageRightsFieldset.style.display = 'none';

}
}

radios.forEach(radio => {
radio.addEventListener('change', toggleSections);
});

// Initial state
toggleSections();
});
	</script>

	<main role="main" id="content">
		<div class="fr-container fr-container--fluid fr-mb-md-14v">
			<div class="fr-grid-row fr-grid-row--gutters fr-grid-row--center">
				<div class="fr-col-12 fr-col-md-10 fr-col-lg-8">
					<div class="fr-container fr-background-alt--grey fr-px-md-0 fr-pt-10v fr-pt-md-14v fr-pb-6v fr-pb-md-10v">
						<div class="fr-grid-row fr-grid-row--gutters fr-grid-row--center">
							<div class="fr-col-12 fr-col-md-10 fr-col-lg-9">
								<h1 class="fr-h1">Adhésion à la MDL</h1>
								<p>
									<strong>La MDL de Fulbert</strong>
								</p>
								<p>La Maison Des Lycéens (MDL) du lycée Fulbert à Chartres est un espace dynamique et collaboratif géré par et pour les élèves.</p>
								<p>Elle a pour but de favoriser le développement culturel et associatif au sein de l'établissement.</p>
								<ul>
									<li>Objectifs : Responsabiliser les élèves, promouvoir la diversité culturelle et créer des espaces d'expression.</li>
									<li>Activités : Organisation d'événements culturels, sportifs et humanitaires.</li>
									<li>Engagement des élèves et soutien de l'administration.</li>
								</ul>
								<p>En résumé, la MDL offre des opportunités d'engagement et de développement personnel.
									<strong>Et ça ne vous coûte que 10€ à l'année.</strong>
								</p>

								{{ form_start(form, {'attr': {'class': 'fr-form'}}) }}

								<fieldset class="fr-fieldset fr-mb-6v" id="radio-inline" aria-labelledby="radio-inline-legend radio-inline-messages">
									<legend class="fr-fieldset__legend fr-fieldset__legend--regular" id="radio-inline-legend">
										<h2>Voulez-vous adhérer à la MDL ?</h2>
									</legend>
									{% for choice in form.accepted %}
										<div class="fr-fieldset__element fr-fieldset__element--inline">
											<div class="fr-radio-group fr-radio-rich">
												{{ form_widget(choice) }}
												{{ form_label(choice, null, {'label_attr': {'class': 'fr-label'}}) }}
											</div>
										</div>
									{% endfor %}
									<div class="fr-messages-group" id="radio-inline-messages" aria-live="assertive"></div>
								</fieldset>

								<fieldset class="fr-fieldset fr-mb-6v" id="payment-method-fieldset" aria-labelledby="payment-method-fieldset-legend">
									<legend class="fr-fieldset__legend fr-text--regular">
										Mode de paiement
									</legend>
									<p>10€ à l'ordre de la MDL, paiement de préférence par chèque.</p>
									{% for choice in form.paymentMethod %}
										<div class="fr-fieldset__element fr-fieldset__element--inline">
											<div class="fr-radio-group fr-radio-rich">
												{{ form_widget(choice) }}
												{{ form_label(choice, null, {'label_attr': {'class': 'fr-label'}}) }}
											</div>
										</div>
									{% endfor %}
								</fieldset>

								<fieldset class="fr-fieldset fr-mb-6v" id="image-rights-inline" aria-labelledby="image-rights-inline-legend image-rights-inline-messages">
									<legend class="fr-fieldset__legend fr-fieldset__legend--regular" id="image-rights-inline-legend">
										Autorisation droit à l'image
									</legend>
									{% for choice in form.imageRights %}
										<div class="fr-fieldset__element fr-fieldset__element--inline">
											<div class="fr-radio-group fr-radio-rich">
												{{ form_widget(choice) }}
												{{ form_label(choice, null, {'label_attr': {'class': 'fr-label'}}) }}
											</div>
										</div>
									{% endfor %}
									<div class="fr-messages-group" id="image-rights-inline-messages" aria-live="assertive"></div>
								</fieldset>

								<div class="fr-form-group">
									<button type="submit" class="fr-btn">Valider</button>
								</div>
								{{ form_end(form) }}
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</main>

{% endblock %}

