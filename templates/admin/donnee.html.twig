{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content %}
    <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

    <div class="container-fluid">
        <!-- En-tête avec le nom de l'élève et son état de complétion -->
        <div class="card mb-4 w-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3>Données de l'élève: {{ user.prenom }} {{ user.nom }}</h3>
                <div class="text-right">
                    {% set completion = globalComparison.user_percentage %}
                    {% if completion < 50 %}
                        <span class="badge bg-danger p-2">{{ completion }}% complété</span>
                    {% elseif completion < 80 %}
                        <span class="badge bg-warning p-2">{{ completion }}% complété</span>
                    {% else %}
                        <span class="badge bg-success p-2">{{ completion }}% complété</span>
                    {% endif %}
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    <!-- Informations personnelles -->
                    <div class="col-lg-6 mb-4">
                        <h4>Informations personnelles</h4>
                        <table class="table">
                            <tr><th style="width: 40%">Nom</th><td>{{ user.nom }}</td></tr>
                            <tr><th>Prénom</th><td>{{ user.prenom }}</td></tr>
                            <tr><th>Email</th><td>{{ user.email }}</td></tr>
                            <tr><th>Compte vérifié</th><td>{{ user.isVerified ? 'Oui' : 'Non' }}</td></tr>
                            
                            {% if user.infoEleve is not null %}
                                <tr>
                                    <th>Date de naissance</th>
                                    <td>{{ user.infoEleve.dateDeNaissance ? user.infoEleve.dateDeNaissance|date('d/m/Y') : 'Non renseignée' }}</td>
                                </tr>
                                <tr>
                                    <th>Classe</th>
                                    <td>{{ user.infoEleve.classe.label ?: 'Non renseignée' }}</td>
                                </tr>
                                <tr>
                                    <th>Promotion</th>
                                    <td>{{ user.infoEleve.promotion ?: 'Non renseignée' }}</td>
                                </tr>
                                <tr>
                                    <th>Téléphone mobile</th>
                                    <td>{{ user.infoEleve.numeroMobile ?: 'Non renseigné' }}</td>
                                </tr>
                            {% endif %}
                        </table>
                    </div>
                    
                    <!-- Graphique de complétion -->
                    <div class="col-lg-6">
                        <h4 class="text-center">État de complétion du profil</h4>
                        <div id="completionChart" style="width: 100%; min-height: 300px;"></div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Comparaison avec la moyenne -->
        <div class="card mb-4 w-100">
            <div class="card-header">
                <h4>Poucentage de complétion du profil</h4>
            </div>
            <div class="card-body">
                <div id="comparisonChart" style="width: 100%; min-height: 250px;"></div>
            </div>
        </div>
        
        <!-- Détail par section -->
        <div class="card mb-4 w-100">
            <div class="card-header">
                <h5 class="mb-3">Top champs manquants</h5>
            </div>
            <div class="card-body">
                <ul class="list-group">
                    {% for field in completionData.missingFields %}
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>{{ field.section|capitalize }} > {{ field.field|capitalize }}</span>
                        </li>
                    {% endfor %}
                </ul>
            </div>
        </div>
        
        <!-- Documents à fournir - Récapitulatif -->
        {% if inscription %}
        <div class="fr-grid-row fr-grid-row--gutters fr-mb-4w">
            <div class="fr-col-12">
                <div class="fr-card fr-card--shadow">
                    <div class="fr-card__body">
                        <div class="fr-card__content">
                            <h2 class="fr-card__title fr-mb-3w">
                                <span class="fr-icon-file-text-line fr-icon--lg fr-mr-2w" aria-hidden="true"></span>
                                Documents fournis
                            </h2>
                            
                            <div class="fr-grid-row fr-grid-row--gutters fr-mt-4w">
                                <div class="fr-col-12 fr-col-md-6">
                                    <!-- Carte Vitale -->
                                    <div class="fr-card fr-card--sm fr-mb-3w fr-card--no-arrow">
                                        <div class="fr-card__body">
                                            <div class="fr-card__content">
                                                <div class="fr-checkbox-group">
                                                    <input type="checkbox" id="carte-vitale" name="carte-vitale" disabled 
                                                        {{ documentManager.hasDocument(inscription, 'carte_vitale') ? 'checked' : '' }}>
                                                    <label class="fr-label document-label-container" for="carte-vitale">
                                                        <div class="fr-grid-row fr-grid-row--middle">
                                                            <div class="fr-col-8">
                                                                <span class="document-label">
                                                                    <span class="document-name fr-text--bold">Carte Vitale</span>
                                                                    <div class="fr-mt-1v">
                                                                        {% if documentManager.hasDocument(inscription, 'carte_vitale') %}
                                                                            <span class="fr-badge fr-badge--success fr-badge--sm">
                                                                                <span class="fr-icon-checkbox-circle-fill fr-icon--sm fr-mr-1v" aria-hidden="true"></span>
                                                                                Fourni
                                                                            </span>
                                                                        {% else %}
                                                                            <span class="fr-badge fr-badge--error fr-badge--sm">
                                                                                <span class="fr-icon-close-circle-fill fr-icon--sm fr-mr-1v" aria-hidden="true"></span>
                                                                                Manquant
                                                                            </span>
                                                                        {% endif %}
                                                                    </div>
                                                                </span>
                                                            </div>
                                                            <div class="fr-col-4 fr-text--right">
                                                                {% if documentManager.hasDocument(inscription, 'carte_vitale') %}
                                                                    <div class="document-actions">
                                                                        <a href="{{ path('download_document', {eleveId: inscription.id, documentType: 'carte_vitale'}) }}" 
                                                                        class="fr-btn fr-btn--tertiary-no-outline fr-btn--sm fr-icon-download-line fr-btn--icon-only"
                                                                        title="Télécharger le document">
                                                                            Télécharger
                                                                        </a>
                                                                    </div>
                                                                {% endif %}
                                                            </div>
                                                        </div>
                                                    </label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Photo d'identité -->
                                    <div class="fr-card fr-card--sm fr-mb-3w fr-card--no-arrow">
                                        <div class="fr-card__body">
                                            <div class="fr-card__content">
                                                <div class="fr-checkbox-group">
                                                    <input type="checkbox" id="photo-identite" name="photo-identite" disabled 
                                                        {{ documentManager.hasDocument(inscription, 'photo_identite') ? 'checked' : '' }}>
                                                    <label class="fr-label document-label-container" for="photo-identite">
                                                        <div class="fr-grid-row fr-grid-row--middle">
                                                            <div class="fr-col-8">
                                                                <span class="document-label">
                                                                    <span class="document-name fr-text--bold">Photo d'identité</span>
                                                                    <div class="fr-mt-1v">
                                                                        {% if documentManager.hasDocument(inscription, 'photo_identite') %}
                                                                            <span class="fr-badge fr-badge--success fr-badge--sm">
                                                                                <span class="fr-icon-checkbox-circle-fill fr-icon--sm fr-mr-1v" aria-hidden="true"></span>
                                                                                Fourni
                                                                            </span>
                                                                        {% else %}
                                                                            <span class="fr-badge fr-badge--error fr-badge--sm">
                                                                                <span class="fr-icon-close-circle-fill fr-icon--sm fr-mr-1v" aria-hidden="true"></span>
                                                                                Manquant
                                                                            </span>
                                                                        {% endif %}
                                                                    </div>
                                                                </span>
                                                            </div>
                                                            <div class="fr-col-4 fr-text--right">
                                                                {% if documentManager.hasDocument(inscription, 'photo_identite') %}
                                                                    <div class="document-actions">
                                                                        <a href="{{ path('download_document', {eleveId: inscription.id, documentType: 'photo_identite'}) }}" 
                                                                        class="fr-btn fr-btn--tertiary-no-outline fr-btn--sm fr-icon-download-line fr-btn--icon-only"
                                                                        title="Télécharger le document">
                                                                            Télécharger
                                                                        </a>
                                                                    </div>
                                                                {% endif %}
                                                            </div>
                                                        </div>
                                                    </label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Attestation d'identité -->
                                    <div class="fr-card fr-card--sm fr-mb-3w fr-card--no-arrow">
                                        <div class="fr-card__body">
                                            <div class="fr-card__content">
                                                <div class="fr-checkbox-group">
                                                    <input type="checkbox" id="attestation-identite" name="attestation-identite" disabled 
                                                        {{ documentManager.hasDocument(inscription, 'attestation_identite') ? 'checked' : '' }}>
                                                    <label class="fr-label document-label-container" for="attestation-identite">
                                                        <div class="fr-grid-row fr-grid-row--middle">
                                                            <div class="fr-col-8">
                                                                <span class="document-label">
                                                                    <span class="document-name fr-text--bold">Attestation d'identité</span>
                                                                    <div class="fr-mt-1v">
                                                                        {% if documentManager.hasDocument(inscription, 'attestation_identite') %}
                                                                            <span class="fr-badge fr-badge--success fr-badge--sm">
                                                                                <span class="fr-icon-checkbox-circle-fill fr-icon--sm fr-mr-1v" aria-hidden="true"></span>
                                                                                Fourni
                                                                            </span>
                                                                        {% else %}
                                                                            <span class="fr-badge fr-badge--error fr-badge--sm">
                                                                                <span class="fr-icon-close-circle-fill fr-icon--sm fr-mr-1v" aria-hidden="true"></span>
                                                                                Manquant
                                                                            </span>
                                                                        {% endif %}
                                                                    </div>
                                                                </span>
                                                            </div>
                                                            <div class="fr-col-4 fr-text--right">
                                                                {% if documentManager.hasDocument(inscription, 'attestation_identite') %}
                                                                    <div class="document-actions">
                                                                        <a href="{{ path('download_document', {eleveId: inscription.id, documentType: 'attestation_identite'}) }}" 
                                                                        class="fr-btn fr-btn--tertiary-no-outline fr-btn--sm fr-icon-download-line fr-btn--icon-only"
                                                                        title="Télécharger le document">
                                                                            Télécharger
                                                                        </a>
                                                                    </div>
                                                                {% endif %}
                                                            </div>
                                                        </div>
                                                    </label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="fr-col-12 fr-col-md-6">
                                    <!-- Bourse -->
                                    <div class="fr-card fr-card--sm fr-mb-3w fr-card--no-arrow">
                                        <div class="fr-card__body">
                                            <div class="fr-card__content">
                                                <div class="fr-checkbox-group">
                                                    <input type="checkbox" id="bourse" name="bourse" disabled 
                                                        {{ documentManager.hasDocument(inscription, 'bourse') ? 'checked' : '' }}>
                                                    <label class="fr-label document-label-container" for="bourse">
                                                        <div class="fr-grid-row fr-grid-row--middle">
                                                            <div class="fr-col-8">
                                                                <span class="document-label">
                                                                    <span class="document-name fr-text--bold">
                                                                        Justificatif de bourse
                                                                    </span>
                                                                    <div class="fr-text--xs fr-text-mention--grey fr-mt-1v">
                                                                        (optionnel)
                                                                    </div>
                                                                    <div class="fr-mt-1v">
                                                                        {% if documentManager.hasDocument(inscription, 'bourse') %}
                                                                            <span class="fr-badge fr-badge--success fr-badge--sm">
                                                                                <span class="fr-icon-checkbox-circle-fill fr-icon--sm fr-mr-1v" aria-hidden="true"></span>
                                                                                Fourni
                                                                            </span>
                                                                        {% else %}
                                                                            <span class="fr-badge fr-badge--info fr-badge--sm">
                                                                                <span class="fr-icon-info-fill fr-icon--sm fr-mr-1v" aria-hidden="true"></span>
                                                                                Non fourni
                                                                            </span>
                                                                        {% endif %}
                                                                    </div>
                                                                </span>
                                                            </div>
                                                            <div class="fr-col-4 fr-text--right">
                                                                {% if documentManager.hasDocument(inscription, 'bourse') %}
                                                                    <div class="document-actions">
                                                                        <a href="{{ path('download_document', {eleveId: inscription.id, documentType: 'bourse'}) }}" 
                                                                        class="fr-btn fr-btn--tertiary-no-outline fr-btn--sm fr-icon-download-line fr-btn--icon-only"
                                                                        title="Télécharger le document">
                                                                            Télécharger
                                                                        </a>
                                                                    </div>
                                                                {% endif %}
                                                            </div>
                                                        </div>
                                                    </label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Attestation JDC -->
                                    <div class="fr-card fr-card--sm fr-mb-3w fr-card--no-arrow">
                                        <div class="fr-card__body">
                                            <div class="fr-card__content">
                                                <div class="fr-checkbox-group">
                                                    <input type="checkbox" id="attestation-jdc" name="attestation-jdc" disabled 
                                                        {{ documentManager.hasDocument(inscription, 'attestation_jdc') ? 'checked' : '' }}>
                                                    <label class="fr-label document-label-container" for="attestation-jdc">
                                                        <div class="fr-grid-row fr-grid-row--middle">
                                                            <div class="fr-col-8">
                                                                <span class="document-label">
                                                                    <span class="document-name fr-text--bold">
                                                                        Attestation JDC
                                                                    </span>
                                                                    <div class="fr-text--xs fr-text-mention--grey fr-mt-1v">
                                                                        (optionnel)
                                                                    </div>
                                                                    <div class="fr-mt-1v">
                                                                        {% if documentManager.hasDocument(inscription, 'attestation_jdc') %}
                                                                            <span class="fr-badge fr-badge--success fr-badge--sm">
                                                                                <span class="fr-icon-checkbox-circle-fill fr-icon--sm fr-mr-1v" aria-hidden="true"></span>
                                                                                Fourni
                                                                            </span>
                                                                        {% else %}
                                                                            <span class="fr-badge fr-badge--info fr-badge--sm">
                                                                                <span class="fr-icon-info-fill fr-icon--sm fr-mr-1v" aria-hidden="true"></span>
                                                                                Non fourni
                                                                            </span>
                                                                        {% endif %}
                                                                    </div>
                                                                </span>
                                                            </div>
                                                            <div class="fr-col-4 fr-text--right">
                                                                {% if documentManager.hasDocument(inscription, 'attestation_jdc') %}
                                                                    <div class="document-actions">
                                                                        <a href="{{ path('download_document', {eleveId: inscription.id, documentType: 'attestation_jdc'}) }}" 
                                                                        class="fr-btn fr-btn--tertiary-no-outline fr-btn--sm fr-icon-download-line fr-btn--icon-only"
                                                                        title="Télécharger le document">
                                                                            Télécharger
                                                                        </a>
                                                                    </div>
                                                                {% endif %}
                                                            </div>
                                                        </div>
                                                    </label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Attestation de réussite -->
                                    <div class="fr-card fr-card--sm fr-mb-3w fr-card--no-arrow">
                                        <div class="fr-card__body">
                                            <div class="fr-card__content">
                                                <div class="fr-checkbox-group">
                                                    <input type="checkbox" id="attestation-reussite" name="attestation-reussite" disabled 
                                                        {{ documentManager.hasDocument(inscription, 'attestation_reusite') ? 'checked' : '' }}>
                                                    <label class="fr-label document-label-container" for="attestation-reussite">
                                                        <div class="fr-grid-row fr-grid-row--middle">
                                                            <div class="fr-col-8">
                                                                <span class="document-label">
                                                                    <span class="document-name fr-text--bold">
                                                                        Attestation de réussite
                                                                    </span>
                                                                    <div class="fr-text--xs fr-text-mention--grey fr-mt-1v">
                                                                        (optionnel)
                                                                    </div>
                                                                    <div class="fr-mt-1v">
                                                                        {% if documentManager.hasDocument(inscription, 'attestation_reusite') %}
                                                                            <span class="fr-badge fr-badge--success fr-badge--sm">
                                                                                <span class="fr-icon-checkbox-circle-fill fr-icon--sm fr-mr-1v" aria-hidden="true"></span>
                                                                                Fourni
                                                                            </span>
                                                                        {% else %}
                                                                            <span class="fr-badge fr-badge--info fr-badge--sm">
                                                                                <span class="fr-icon-info-fill fr-icon--sm fr-mr-1v" aria-hidden="true"></span>
                                                                                Non fourni
                                                                            </span>
                                                                        {% endif %}
                                                                    </div>
                                                                </span>
                                                            </div>
                                                            <div class="fr-col-4 fr-text--right">
                                                                {% if documentManager.hasDocument(inscription, 'attestation_reusite') %}
                                                                    <div class="document-actions">
                                                                        <a href="{{ path('download_document', {eleveId: inscription.id, documentType: 'attestation_reusite'}) }}" 
                                                                        class="fr-btn fr-btn--tertiary-no-outline fr-btn--sm fr-icon-download-line fr-btn--icon-only"
                                                                        title="Télécharger le document">
                                                                            Télécharger
                                                                        </a>
                                                                    </div>
                                                                {% endif %}
                                                            </div>
                                                        </div>
                                                    </label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Résumé des documents -->
                            <div class="fr-mt-5w">
                                {% if documentsStatus is defined and documentsStatus %}
                                    {% set totalDocuments = documentsStatus|length %}
                                    {% set uploadedDocuments = 0 %}
                                    {% set requiredDocuments = 0 %}
                                    {% set uploadedRequiredDocuments = 0 %}
                                    
                                    {% for type, status in documentsStatus %}
                                        {% if status.uploaded %}
                                            {% set uploadedDocuments = uploadedDocuments + 1 %}
                                        {% endif %}
                                        {% if status.required %}
                                            {% set requiredDocuments = requiredDocuments + 1 %}
                                            {% if status.uploaded %}
                                                {% set uploadedRequiredDocuments = uploadedRequiredDocuments + 1 %}
                                            {% endif %}
                                        {% endif %}
                                    {% endfor %}

                                    <div class="fr-card fr-card--sm fr-card--grey">
                                        <div class="fr-card__body">
                                            <div class="fr-card__content">
                                                <h3 class="fr-card__title fr-text--lg fr-mb-3w">
                                                    <span class="fr-icon-survey-line fr-icon--sm fr-mr-1w" aria-hidden="true"></span>
                                                    Récapitulatif du dossier
                                                </h3>
                                                
                                                <div class="fr-grid-row fr-grid-row--gutters">
                                                    <div class="fr-col-12 fr-col-md-4">
                                                        <div class="fr-card fr-card--sm fr-card--no-arrow">
                                                            <div class="fr-card__body">
                                                                <div class="fr-card__content fr-text--center">
                                                                    <div class="fr-text--xl fr-text--bold {{ uploadedRequiredDocuments == requiredDocuments ? 'fr-text--success' : 'fr-text--warning' }}">
                                                                        {{ uploadedRequiredDocuments }}/{{ requiredDocuments }}
                                                                    </div>
                                                                    <div class="fr-text--sm fr-text-mention--grey">
                                                                        Documents obligatoires
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="fr-col-12 fr-col-md-4">
                                                        <div class="fr-card fr-card--sm fr-card--no-arrow">
                                                            <div class="fr-card__body">
                                                                <div class="fr-card__content fr-text--center">
                                                                    <div class="fr-text--xl fr-text--bold fr-text--info">
                                                                        {{ uploadedDocuments }}/{{ totalDocuments }}
                                                                    </div>
                                                                    <div class="fr-text--sm fr-text-mention--grey">
                                                                        Total des documents
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="fr-col-12 fr-col-md-4">
                                                        <div class="fr-card fr-card--sm fr-card--no-arrow">
                                                            <div class="fr-card__body">
                                                                <div class="fr-card__content fr-text--center">
                                                                    {% if hasAllRequiredDocuments is defined and hasAllRequiredDocuments %}
                                                                        <div class="fr-text--lg fr-text--bold fr-text--success fr-mb-1v">
                                                                            <span class="fr-icon-checkbox-circle-fill fr-icon--lg" aria-hidden="true"></span>
                                                                        </div>
                                                                        <div class="fr-text--sm fr-text--success">
                                                                            Dossier complet
                                                                        </div>
                                                                    {% else %}
                                                                        <div class="fr-text--lg fr-text--bold fr-text--warning fr-mb-1v">
                                                                            <span class="fr-icon-warning-fill fr-icon--lg" aria-hidden="true"></span>
                                                                        </div>
                                                                        <div class="fr-text--sm fr-text--warning">
                                                                            Documents manquants
                                                                        </div>
                                                                    {% endif %}
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {% else %}
        <!-- Message si aucune inscription -->
        <div class="fr-grid-row fr-grid-row--gutters fr-mb-4w">
            <div class="fr-col-12">
                <div class="fr-card fr-card--shadow">
                    <div class="fr-card__body">
                        <div class="fr-card__content">
                            <h2 class="fr-card__title fr-mb-3w">
                                <span class="fr-icon-file-text-line fr-icon--lg fr-mr-2w" aria-hidden="true"></span>
                                Documents à fournir
                            </h2>
                            <div class="fr-alert fr-alert--info">
                                <h3 class="fr-alert__title">Information</h3>
                                <p>Aucune inscription trouvée. Veuillez d'abord compléter votre inscription pour accéder à la gestion des documents.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}
        
        <!-- Dossiers PDF -->
        <div class="card w-100 mb-4">
            <div class="card-header">
                <h4>Dossiers PDF pour {{ user.prenom }} {{ user.nom }}</h4>
            </div>
            <div class="card-body">
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>Type</th>
                            <th>Statut</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for type, data in pdfs %}
                            <tr>
                                <td>{{ type|capitalize }}</td>
                                <td>
                                    {% if data.exists %}
                                        <span class="badge bg-success">Généré</span>
                                    {% else %}
                                        <span class="badge bg-danger">Non généré</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if data.exists %}
                                        <a href="{{ asset(data.path) }}" class="btn btn-sm btn-primary" target="_blank">Visualiser</a>
                                        <a href="{{ asset(data.path) }}" class="btn btn-sm btn-secondary" download>Télécharger</a>
                                    {% else %}
                                        <a href="{{ path('generer_docx_' ~ type, {'id': user.infoEleve.id}) }}" class="btn btn-sm btn-warning">Générer</a>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        
        <!-- Actions -->
        <div class="card w-100 mb-4">
            <div class="card-header">
                <h4>Actions</h4>
            </div>
            <div class="card-body">
                <a href="{{ path('admin_email_form', {'id': user.id}) }}" class="btn btn-primary">
                    <i class="fa fa-envelope"></i> Envoyer un email
                </a>
                <a href="{{ path('admin') }}" class="btn btn-outline-dark">
                    <i class="fa fa-arrow-left"></i> Retour au dashboard
                </a>
            </div>
        </div>
    </div>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Fonction pour ajuster les graphiques à la taille de l'écran
            function createResponsiveCharts() {
                // Graphique de complétion du profil utilisateur
                var completionOptions = {
                    series: [{{ completionData.completion.complete }}, {{ completionData.completion.incomplete }}],
                    chart: {
                        type: 'pie',
                        height: 350,
                        width: '100%',
                        redrawOnWindowResize: true
                    },
                    labels: ['Données complètes', 'Données manquantes'],
                    colors: ['#4CAF50', '#F44336'],
                    title: {
                        text: 'Complétion du profil',
                        align: 'center',
                        style: {
                            fontSize: '16px',
                            fontWeight: 600
                        }
                    },
                    legend: {
                        position: 'bottom'
                    },
                    tooltip: {
                        y: {
                            formatter: function(val) {
                                return val + ' données';
                            }
                        }
                    },
                    responsive: [{
                        breakpoint: 480,
                        options: {
                            chart: {
                                height: 300
                            },
                            legend: {
                                position: 'bottom'
                            }
                        }
                    }]
                };
                
                var completionChart = new ApexCharts(document.querySelector("#completionChart"), completionOptions);
                completionChart.render();
                
                // Graphique de comparaison avec la moyenne des élèves
                var comparisonOptions = {
                    series: [{
                        name: 'Profil de l\'élève',
                        data: [{{ globalComparison.user_percentage }}]
                    }],
                    chart: {
                        type: 'bar',
                        height: 250,
                        toolbar: {
                            show: false
                        }
                    },
                    plotOptions: {
                        bar: {
                            horizontal: false,
                            columnWidth: '55%',
                            endingShape: 'rounded'
                        },
                    },
                    dataLabels: {
                        enabled: true,
                        formatter: function(val) {
                            return val + '%';
                        }
                    },
                    stroke: {
                        show: true,
                        width: 2,
                        colors: ['transparent']
                    },
                    xaxis: {
                        categories: ['Taux de complétion'],
                    },
                    yaxis: {
                        title: {
                            text: 'Pourcentage (%)'
                        },
                        min: 0,
                        max: 100
                    },
                    fill: {
                        opacity: 1,
                        colors: ['#2196F3', '#9E9E9E']
                    },
                    tooltip: {
                        y: {
                            formatter: function(val) {
                                return val + "%";
                            }
                        }
                    }
                };

                var comparisonChart = new ApexCharts(document.querySelector("#comparisonChart"), comparisonOptions);
                comparisonChart.render();
                
                
                
                var sectionsOptions = {
                    series: [{
                        name: 'Complétion',
                        data: sectionsData.map(function(item) { return item.value; })
                    }],
                    chart: {
                        type: 'bar',
                        height: 400
                    },
                    plotOptions: {
                        bar: {
                            borderRadius: 4,
                            horizontal: true,
                            distributed: true,
                            dataLabels: {
                                position: 'bottom'
                            },
                        }
                    },
                    colors: ['#33b2df', '#546E7A', '#d4526e', '#13d8aa', '#A5978B', '#4ecdc4', '#c7f464', '#81D4FA'],
                    dataLabels: {
                        enabled: true,
                        textAnchor: 'start',
                        style: {
                            colors: ['#fff']
                        },
                        formatter: function(val) {
                            return val + '%';
                        },
                        offsetX: 0
                    },
                    stroke: {
                        width: 1,
                        colors: ['#fff']
                    },
                    xaxis: {
                        categories: sectionsData.map(function(item) { return item.section; })
                    },
                    yaxis: {
                        labels: {
                            show: false
                        }
                    },
                    tooltip: {
                        theme: 'dark',
                        y: {
                            formatter: function(val) {
                                return val + '%';
                            }
                        }
                    }
                };

                var sectionsChart = new ApexCharts(document.querySelector("#sectionsChart"), sectionsOptions);
                sectionsChart.render();
            }
            
            // Appeler la fonction pour créer les graphiques
            createResponsiveCharts();
            
            // Redimensionner les graphiques lors du redimensionnement de la fenêtre
            window.addEventListener('resize', function() {
                // Redessiner les graphiques si nécessaire
                if (typeof completionChart !== 'undefined') completionChart.render();
                if (typeof comparisonChart !== 'undefined') comparisonChart.render();
                if (typeof sectionsChart !== 'undefined') sectionsChart.render();
            });
        });
    </script>
{% endblock %}